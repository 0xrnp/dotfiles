# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Auto-generated / cache
*.log
*.tmp
tool_state
*.zwc

# Secrets — never commit
.env
.env.*
*.pem
*.key

# Android (from .config)
.android/

# Cursor — auto-generated session data
cursor/.config/cursor/acp-sessions/
cursor/.config/cursor/User/workspaceStorage/
cursor/.config/cursor/User/History/
cursor/.config/cursor/logs/
cursor/.config/cursor/CachedData/
cursor/.config/cursor/CachedExtensions/

# Zed — auto-generated
zed/.config/zed/conversations/
zed/.config/zed/embeddings/
zed/.config/zed/db/

# General
*.db
*.db-shm
*.db-wal
*.sqlite

# Cursor — additional cache files
cursor/.config/cursor/statsig-cache.json
cursor/.config/cursor/cli-config.json
cursor/.config/cursor/acp-config.json

# Zed — prompt database
zed/.config/zed/prompts/

# SwiftPM — symlinks to system paths, not real config
swiftpm/.config/swiftpm/cache
swiftpm/.config/swiftpm/configuration
swiftpm/.config/swiftpm/security

# Flutter auto-generated
flutter/.config/flutter/tool_state

# opencode
opencode/.config/opencode/.DS_Store
opencode/.config/opencode/skills/.DS_Store

# MDB database files
*.mdb
